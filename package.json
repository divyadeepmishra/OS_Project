{
  "name": "os-project-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd Backened && npm install && cd ../Frontend && npm install",
    "start-backend": "cd Backened && node server.js",
    "start-frontend": "cd Frontend && npm run dev",
    "start": "concurrently \"npm run start-backend\" \"npm run start-frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
